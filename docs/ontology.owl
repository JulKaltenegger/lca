    <owl:Ontology rdf:about="https://w3id.org/lca#">
        <terms:contributor rdf:resource="http://www.semanticweb.org/20180031/ontologies/2026/3/untitled-ontology-42#Martin_Röck"/>
        <terms:creator rdf:resource="http://www.semanticweb.org/20180031/ontologies/2026/3/untitled-ontology-42#Julia_Kaltenegger"/>
        <terms:description>The Life Cycle Assessment ontology assignes Life Cycle Inventories to construction materials. The Life Cycle Inventory is discussed and outlines the required input and output for Life Cycle Assessment calculations.</terms:description>
        <terms:title>Life Cycle Assessment Ontology for building material performance</terms:title>
    </owl:Ontology>
    


